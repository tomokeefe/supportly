# Resolvly Environment Variables

# PostgreSQL connection string (optional — app runs in demo mode without it)
# DATABASE_URL=postgresql://user:password@localhost:5432/resolvly

# Anthropic API key for Claude (optional — app uses keyword matching without it)
# ANTHROPIC_API_KEY=sk-ant-...

# Clerk authentication (optional — app runs without auth when not configured)
# Get your keys at https://dashboard.clerk.com
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
# CLERK_SECRET_KEY=sk_test_...

# Clerk redirect URLs
# NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
# NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
# NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
# NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding

# Stripe billing (optional — billing features disabled without it)
# Get your keys at https://dashboard.stripe.com/apikeys
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs (create these in the Stripe dashboard under Products)
# STRIPE_PRICE_STARTER=price_...
# STRIPE_PRICE_PRO=price_...
# STRIPE_PRICE_BUSINESS=price_...

# Umami Analytics (optional — get your website ID from cloud.umami.is)
# NEXT_PUBLIC_UMAMI_WEBSITE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
